#!/usr/bin/env bash
# Exit the script if a command fails
set -e

CONFIG_REPO=~/.config-repo

# ── Install tools ────────────────────────────────────────────────────────────

# FIXME: Installing tools are not tested. Remove this comment after testing

# Install Neovim if not found
if [ ! -f /opt/nvim-linux-x86_64/bin/nvim ]; then
  echo "Installing Neovim (latest release)..."
  curl -LO https://github.com/neovim/neovim/releases/latest/download/nvim-linux-x86_64.tar.gz
  sudo tar -C /opt -xzf nvim-linux-x86_64.tar.gz
  rm nvim-linux-x86_64.tar.gz
fi

# Install Ghostty if not found (Ubuntu)
if ! command -v ghostty &> /dev/null; then
  echo "Installing Ghostty..."
  curl -fsSL https://raw.githubusercontent.com/mkasberg/ghostty-ubuntu/HEAD/install.sh | bash
fi

# Install Starship if not found
if ! command -v starship &> /dev/null; then
  echo "Installing Starship..."
  curl -sS https://starship.rs/install.sh | sh
fi

# Install zsh-autosuggestions
if [ ! -d "$HOME/.zsh/zsh-autosuggestions" ]; then
  echo "Installing zsh-autosuggestions..."
  git clone https://github.com/zsh-users/zsh-autosuggestions "$HOME/.zsh/zsh-autosuggestions"
fi

# Install zsh-syntax-highlighting
if [ ! -d "$HOME/.zsh/zsh-syntax-highlighting" ]; then
  echo "Installing zsh-syntax-highlighting..."
  git clone https://github.com/zsh-users/zsh-syntax-highlighting.git "$HOME/.zsh/zsh-syntax-highlighting"
fi

# ── Link files and directories into home ─────────────────────────────────────

HOME_ITEMS=( .profile .zshrc .zsh_aliases )

for item in "${HOME_ITEMS[@]}"; do
  # Remove if it's a real directory, not a symlink (symlinks are replaced by ln -snfT)
  if [ -d ~/"${item}" ] && [ ! -L ~/"${item}" ]; then
    rm -rf ~/"${item}"
  fi
  ln -snfT "${CONFIG_REPO}/${item}" ~/"${item}"
  echo "Linked: ${item}"
done

# ── Link files and directories into ~/.config ─────────────────────────────────

CONFIG_ITEMS=( nvim ghostty starship.toml )

for item in "${CONFIG_ITEMS[@]}"; do
  # Remove if it's a real directory, not a symlink (symlinks are replaced by ln -snfT)
  if [ -d ~/.config/"${item}" ] && [ ! -L ~/.config/"${item}" ]; then
    rm -rf ~/.config/"${item}"
  fi
  ln -snfT "${CONFIG_REPO}/.config/${item}" ~/.config/"${item}"
  echo "Linked: ~/.config/${item}"
done

# ── Link Claude config ────────────────────────────────────────────────────────

# Link config files individually to preserve existing ~/.claude contents
ln -sf "${CONFIG_REPO}/.claude/CLAUDE.md" ~/.claude/CLAUDE.md
echo "Linked: .claude/CLAUDE.md"
ln -sf "${CONFIG_REPO}/.claude/settings.json" ~/.claude/settings.json
echo "Linked: .claude/settings.json"
ln -sf "${CONFIG_REPO}/.claude/statusline.sh" ~/.claude/statusline.sh
echo "Linked: .claude/statusline.sh"

# Link memory directories for each project, creating the project directory if needed
for project_dir in "${CONFIG_REPO}/.claude/projects"/*/; do
  project="${project_dir%/}"
  project="${project##*/}"
  mkdir -p ~/.claude/projects/"${project}"
  ln -snfT "${CONFIG_REPO}/.claude/projects/${project}/memory" ~/.claude/projects/"${project}"/memory
  echo "Linked: .claude/projects/${project}/memory"
done

echo "✅ Installed"
